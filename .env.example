# Copy to .env and fill in. The .env file is gitignored and should be
# root-readable only on the appliance (chmod 600).

# Finnhub API key (free at finnhub.io) — enables real-time streaming quotes
# and the Finnhub REST fallback. Without it, markets uses keyless Yahoo
# polling, which some networks rate-limit.
FINNHUB_KEY=

# Home Assistant (leave blank to disable the HA bridge)
HA_URL=http://homeassistant.local:8123
HA_TOKEN=

# Proxmox stretch module (enable in config too)
# PVE_URL=https://pve.local:8006
# PVE_TOKEN_ID=ticker@pam!ticker
# PVE_TOKEN_SECRET=
# PVE_VERIFY_SSL=0

# ADS-B flight radar — defaults to a free hosted API (no key/hardware needed).
# ADSB_URL is ONLY required when modules.adsb.provider is set to "local"
# (your own dump1090/readsb receiver's aircraft.json):
# ADSB_URL=http://pi-adsb:8080/data/aircraft.json

# Fantasy football — only needed for PRIVATE ESPN leagues. Copy both cookies
# from a logged-in espn.com browser session (DevTools → Application → Cookies):
# ESPN_SWID includes the surrounding braces, e.g. {AB12...}. Public leagues
# need neither. Set the league_id / team_id in the admin GUI, not here.
# ESPN_S2=
# ESPN_SWID=

# Optional overrides
# TICKER_DB=/opt/edge-ticker/data/ticker.db
# LOG_LEVEL=INFO
