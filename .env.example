# Copy to .env and fill in. The .env file is gitignored and should be
# root-readable only on the appliance (chmod 600).

# Finnhub API key — used by the Phase 6 markets WebSocket upgrade.
# The default polling collector needs no key.
FINNHUB_KEY=

# Home Assistant (leave blank to disable the HA bridge)
HA_URL=http://homeassistant.local:8123
HA_TOKEN=

# Optional overrides
# TICKER_DB=/opt/edge-ticker/data/ticker.db
# LOG_LEVEL=INFO
